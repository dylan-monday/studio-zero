{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "api/_lib/**"
    }
  },
  "crons": [
    { "path": "/api/cron/checkin-reminders", "schedule": "0 17 * * *" }
  ]
}
